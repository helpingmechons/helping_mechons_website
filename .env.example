# ============================================================
# Helping Mechons — Environment Variables
# Copy this file to .env.local for local development.
# Set all of these on Vercel before deployment.
# ============================================================

# ──────────────────────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ──────────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-vercel-domain.vercel.app
NEXT_PUBLIC_ORG_NAME=Helping Mechons
NEXT_PUBLIC_ORG_UPI_ID=helpingmechons@upi

# ──────────────────────────────────────────────────────────────
# Gmail SMTP (for donation confirmation & receipt emails)
# ──────────────────────────────────────────────────────────────
# Enable 2FA on Gmail, then generate an App Password at:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=helpingmechons@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD_HERE
SMTP_FROM_NAME=Helping Mechons
SMTP_FROM_EMAIL=helpingmechons@gmail.com

# ──────────────────────────────────────────────────────────────
# Google Drive (for gallery image uploads by admin)
# ──────────────────────────────────────────────────────────────
# 1. Create a project at https://console.cloud.google.com
# 2. Enable the Google Drive API
# 3. Create a Service Account → create a key (JSON)
# 4. Base64 encode the key: cat key.json | base64 -w0
# 5. Share your target folder with the service account email
GOOGLE_DRIVE_SERVICE_ACCOUNT_BASE64=YOUR_BASE64_ENCODED_SERVICE_ACCOUNT_JSON
GOOGLE_DRIVE_FOLDER_ID=YOUR_GOOGLE_DRIVE_FOLDER_ID

# ──────────────────────────────────────────────────────────────
# Admin Seed (reference only — DO NOT commit real values)
# ──────────────────────────────────────────────────────────────
# Used to document the initial admin credentials.
# Create this user in Supabase Auth, then elevate role via seed.sql
SEED_ADMIN_EMAIL=helpingmechons@gmail.com
# Default password — must be changed on first login
SEED_ADMIN_PASSWORD=HelpingMechons@2026
