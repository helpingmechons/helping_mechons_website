# ============================================================
# Helping Mechons — Environment Variables
# Copy this file to .env.local for local development.
# Set all of these on Vercel before deployment.
# ============================================================

# ──────────────────────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ──────────────────────────────────────────────────────────────
# Application
# IMPORTANT: Set this to your actual production URL (e.g. https://helping-mechons.vercel.app)
# This is used in signup emails so the confirmation link goes to production, NOT localhost.
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://helping-mechons.vercel.app
NEXT_PUBLIC_ORG_NAME=Helping Mechons
NEXT_PUBLIC_ORG_UPI_ID=tdurgaprasad503@ybl

# ──────────────────────────────────────────────────────────────
# Gmail SMTP (for donation confirmation & receipt emails)
# ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=helpingmechons@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD_HERE
SMTP_FROM_NAME=Helping Mechons
SMTP_FROM_EMAIL=helpingmechons@gmail.com

# ──────────────────────────────────────────────────────────────
# Google Drive (for gallery image uploads by admin)
# ──────────────────────────────────────────────────────────────
GOOGLE_DRIVE_SERVICE_ACCOUNT_BASE64=YOUR_BASE64_ENCODED_SERVICE_ACCOUNT_JSON
GOOGLE_DRIVE_FOLDER_ID=YOUR_GOOGLE_DRIVE_FOLDER_ID

# ──────────────────────────────────────────────────────────────
# Admin Seed (reference only — DO NOT commit real values)
# ──────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=helpingmechons@gmail.com
SEED_ADMIN_PASSWORD=HelpingMechons@2026

# ──────────────────────────────────────────────────────────────
# Razorpay (online payments)
# Get from: razorpay.com → Settings → API Keys
# Use Test keys for development, Live keys for production.
# Once you add these and redeploy, Razorpay payments will be live.
# ──────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
# NOTE: NEXT_PUBLIC_RAZORPAY_KEY_ID is safe to expose to browser.
# RAZORPAY_KEY_SECRET must NEVER be exposed — server-side only.
